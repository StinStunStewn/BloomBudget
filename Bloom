const getAdminConfig = () => {
try {
const r = localStorage.getItem(ADMIN_KEY);
if (r) return JSON.parse(r);
} catch(e) {}
return { kofiUrl: “https://ko-fi.com/YOUR_KOFI_USERNAME”, feedbackEmail: “YOUR_EMAIL@example.com” };
};

const saveAdminConfig = (cfg) => {
try { localStorage.setItem(ADMIN_KEY, JSON.stringify(cfg)); } catch(e) {}
};
const hasTutorialBeenSeen = () => { try { return !!localStorage.getItem(TUTORIAL_KEY); } catch(e) { return false; } };
