.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; margin-bottom: 24px; }
.stat-card { background: var(–surface); border-radius: var(–radius); border: 1px solid var(–border); padding: 18px 20px; }
.stat-label { font-size: 12px; color: var(–text3); text-transform: uppercase; letter-spacing: 0.06em; }
.stat-value { font-family: ‘Nunito’, sans-serif; font-weight: 600; font-size: 26px; color: var(–text); margin: 4px 0 2px; }
.stat-sub { font-size: 12px; color: var(–text3); }
.stat-card.berry { border-left: 3px solid var(–berry); }
.stat-card.sage { border-left: 3px solid var(–sage); }
.stat-card.warm { border-left: 3px solid var(–warm); }
.stat-card.gold { border-left: 3px solid var(–gold); }

/* Expense list */
.expense-item {
display: flex; align-items: center; gap: 14px; padding: 14px 16px;
border-radius: var(–radius-sm); background: var(–surface);
border: 1px solid var(–border); margin-bottom: 8px; transition: all 0.15s;
}
.expense-item:hover { border-color: var(–berry-mid); box-shadow: var(–shadow); }
.expense-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
.expense-name { font-size: 14px; font-weight: 500; color: var(–text); }
