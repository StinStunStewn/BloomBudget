background: var(–surface2); font-family: ‘Nunito’; font-size: 14px; color: var(–text);
transition: all 0.15s; outline: none;
}
.field input:focus, .field select:focus, .field textarea:focus { border-color: var(–berry-mid); box-shadow: 0 0 0 3px var(–berry-light); }
.field textarea { resize: vertical; min-height: 70px; }
.field-hint { font-size: 11px; color: var(–text3); }

