.modal-overlay { position: fixed; inset: 0; background: rgba(58,46,38,0.35); display: flex; align-items: center; justify-content: center; z-index: 100; padding: 20px; backdrop-filter: blur(2px); }
.modal { background: var(–surface); border-radius: 20px; padding: 28px; max-width: 520px; width: 100%; max-height: 90vh; overflow-y: auto; box-shadow: var(–shadow-lg); border: 1px solid var(–border); }
.modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px; }
.modal-title { font-family: ‘Nunito’, sans-serif; font-weight: 600; font-size: 20px; }

/* Budget bar */
.budget-bar-wrap { margin: 8px 0 4px; }
.budget-bar-bg { height: 8px; border-radius: 100px; background: var(–border); overflow: hidden; }
.budget-bar-fill { height: 100%; border-radius: 100px; transition: width 0.6s ease; }

/* Calendar */
.cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 3px; }
.cal-header-cell { text-align: center; font-size: 11px; color: var(–text3); padding: 6px 2px; text-transform: uppercase; letter-spacing: 0.05em; }
.cal-day {
height: 44px; display: flex; flex-direction: column; align-items: center; justify-content: center;
border-radius: 8px; font-size: 13px; cursor: default; gap: 2px; min-width: 0;
}
.cal-day.today { background: var(–berry-light); color: var(–berry); font-weight: 600; }
.cal-day.has-event { background: var(–warm-light); }
.cal-day-dot { width: 5px; height: 5px; border-radius: 50%; background: var(–warm); flex-shrink: 0; }
