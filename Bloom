.expense-amount { font-family: ‘Nunito’, sans-serif; font-weight: 600; font-size: 17px; color: var(–text); margin-left: auto; white-space: nowrap; }
.expense-amount.recurring { color: var(–berry); }
.tag-chip { display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 100px; background: var(–gold-light); color: var(–gold); font-size: 11px; font-weight: 500; }
