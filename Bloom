// ─── Styles ───────────────────────────────────────────────────────────────────
const styles = `
@import url(‘https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;500;600;700&display=swap’);

- { box-sizing: border-box; margin: 0; padding: 0; }

:root {
–bg: #1A1118;
–surface: #261820;
–surface2: #2E1E28;
–border: #3E2838;
–text: #F5EEF0;
