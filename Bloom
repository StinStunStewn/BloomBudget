const saveData = async (data) => {
try { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); } catch(e) {}
};

const loadData = async () => {
try { const r = localStorage.getItem(STORAGE_KEY); if (r) { const p = JSON.parse(r); if (p && Array.isArray(p.expenses)) return p; } } catch(e) {}
return null;
};

