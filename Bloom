const getAcc = id => data.accounts.find(a => a.id === id);

const allTags = […new Set(data.expenses.flatMap(e => e.tags || []))].sort();

const getDateRange = () => {
const now = new Date();
if (period === “week”) {
const mon = new Date(now); mon.setDate(now.getDate() - now.getDay() + 1); mon.setHours(0,0,0,0);
const sun = new Date(mon); sun.setDate(mon.getDate() + 6); sun.setHours(23,59,59,999);
return [mon, sun];
}
if (period === “month”) {
return [new Date(now.getFullYear(), now.getMonth(), 1), new Date(now.getFullYear(), now.getMonth()+1, 0, 23, 59, 59)];
}
if (period === “year”) {
return [new Date(now.getFullYear(), 0, 1), new Date(now.getFullYear(), 11, 31, 23, 59, 59)];
}
if (period === “custom”) {
return [customFrom ? new Date(customFrom) : new Date(0), customTo ? new Date(customTo + “T23:59:59”) : new Date()];
}
return [new Date(0), new Date()]; // all time
};

const getFilteredExpenses = () => {
const [from, to] = getDateRange();
return data.expenses.filter(e => {
if (!e.date) return false;
const d = new Date(e.date);
if (d < from || d > to) return false;
if (filterType === “category” && filterValue && e.categoryId !== filterValue) return false;
if (filterType === “tag” && filterValue && !(e.tags || []).includes(filterValue)) return false;
return true;
}).sort((a, b) => new Date(a.date) - new Date(b.date));
};

