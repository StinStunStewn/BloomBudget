border-radius: var(–radius-sm); border: none; background: none; cursor: pointer;
font-family: ‘Nunito’; font-size: 14px; color: var(–text2); text-align: left;
transition: all 0.18s cubic-bezier(0.34,1.56,0.64,1); width: 100%;
transform-origin: left center;
}
.nav-btn:hover { background: var(–surface2); color: var(–text); }
.nav-btn.active { font-weight: 700; transform: scale(1.04); background: rgba(255,255,255,0.06); }
.nav-btn.active { font-weight: 700; transform: scale(1.04); }
.nav-icon-pill {
width: 34px; height: 34px; border-radius: 9px; display: flex; align-items: center;
justify-content: center; flex-shrink: 0; transition: all 0.18s;
}
.nav-section { font-size: 11px; color: var(–text3); text-transform: uppercase; letter-spacing: 0.08em; padding: 16px 12px 4px; }

/* Main */
.main { flex: 1; overflow-y: auto; background: var(–bg); background-image: radial-gradient(ellipse at 15% 0%, #2E1020 0%, transparent 55%), radial-gradient(ellipse at 85% 100%, #0E2820 0%, transparent 55%); }
.page { padding: 32px; max-width: 960px; }
.page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; }
.page-title { font-family: ‘Nunito’, sans-serif; font-weight: 600; font-size: 28px; color: var(–text); }
.page-subtitle { font-size: 14px; color: var(–text3); margin-top: 2px; }

/* Cards */
.card { background: var(–surface); border-radius: var(–radius); border: 1px solid var(–border); padding: 20px; }
.card-sm { background: var(–surface); border-radius: var(–radius-sm); border: 1px solid var(–border); padding: 16px; }

/* Buttons */
.btn { display: inline-flex; align-items: center; gap: 6px; padding: 9px 16px; border-radius: 100px; border: none; cursor: pointer; font-family: ‘Nunito’; font-size: 13px; font-weight: 500; transition: all 0.15s; }
.btn-primary { background: var(–berry); color: white; }
.btn-primary:hover { background: #B55A6A; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(196,105,122,0.3); }
.btn-secondary { background: var(–surface2); color: var(–text2); border: 1px solid var(–border); }
.btn-secondary:hover { background: var(–border); }
.btn-ghost { background: none; color: var(–text2); }
.btn-ghost:hover { background: var(–surface2); }
.btn-danger { background: #FDE8E8; color: #C45A5A; }
.btn-danger:hover { background: #F8D0D0; }
.btn-sm { padding: 6px 12px; font-size: 12px; }
.btn-icon { padding: 7px; border-radius: 8px; background: none; border: none; cursor: pointer; color: var(–text3); transition: all 0.15s; display: inline-flex; }
.btn-icon:hover { background: var(–surface2); color: var(–text); }

